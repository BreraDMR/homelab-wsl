DB_HOST=sphynx-db
DB_NAME=sphynx_prague
DB_USER=sphynx
DB_PASSWORD=change-me

# demo admin: admin / sphynx-admin-2026 -- CHANGE before going public:
#   php -r "echo password_hash('new-pass', PASSWORD_BCRYPT), PHP_EOL;"
#
# GOTCHA: docker compose interpolates $VAR / ${VAR} inside env_file values
# too, not just in compose.yaml itself. A bcrypt hash is full of $ followed
# by random base64-ish text, so whenever a $ happens to be followed by a
# letter (matches docker compose's bare-variable pattern), compose treats
# the rest of the hash as an undefined variable name and replaces it with
# an empty string -- silently truncating the hash and breaking login.
# Escape every literal $ as $$ when pasting a freshly generated hash here:
#   echo "$HASH" | sed 's/\$/\$\$/g'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$/aHMxiyAvkalENkqc2.5xOQJTdj6ua/Mb2qJ8TIbp6RUb9yJzqQhi

# Shared secret for api/cats.php's bot-facing endpoints -- must match
# bot.env's BOT_API_KEY for sphynx-cats-crm-bot. Generate with:
#   openssl rand -hex 24
BOT_API_KEY=
