# Shared env for homelab stacks. Copy to .env (gitignored) and fill in.
# Bots read their token from here via `env_file: ../../.env`.

# --- bots ---
# MYBOT_TOKEN=123456:ABCdef...

# --- ollama ---
OLLAMA_HOST=http://ollama:11434

# --- bot: pc-tele-monitor-ai ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# admin telegram id(s), comma-separated (from @userinfobot)
ADMIN_TELEGRAM_IDS=YOUR_TELEGRAM_ID
# whisper size for voice msgs: tiny/base/small/medium
WHISPER_MODEL_SIZE=base
